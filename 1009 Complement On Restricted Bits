int bitwiseComplement(int n) {
    if(n==0){
        return 1;
    }
    int tracker=0;
    int masker=1;
    for(int i=0;i<30;i++){
        if((n & masker)!=0){
            tracker=i+1;
        }
        masker<<=1;
    }
    int mask=1;
    int value=0;
    for(int j=0;j<tracker;j++){
        if((n & mask)==0){
            value+=mask;
        }
        mask<<=1;
    }
    return value;
}
