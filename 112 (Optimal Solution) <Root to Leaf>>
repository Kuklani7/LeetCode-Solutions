/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public boolean hasPathSum(TreeNode root, int targetSum) {
        boolean hecker=summer(root,0,targetSum);
        return hecker;
    }
    private static boolean summer(TreeNode node,int result,int targetSum){
        if(node==null){
            return false;
        }
        result+=node.val;
        if(node.left==null && node.right==null && result==targetSum){
            return true;
        }
        if(summer(node.left,result,targetSum)){
            return true;
        }
        if(summer(node.right,result,targetSum)){
            return true;
        }
        return false;
    }
}
