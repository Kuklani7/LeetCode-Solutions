/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public boolean hasPathSum(TreeNode root, int targetSum) {
        ArrayList<Integer> results=new ArrayList<>();
        summer(root,0,results);
        for(int x:results){
            if(x==targetSum){
                return true;
            }
        }
        return false;
    }
    private static void summer(TreeNode node, int result, ArrayList<Integer> results){
        if(node==null){
            return;
        }
        result+=node.val;
        if(node.left==null && node.right==null){
            results.add(result);
        }
        summer(node.left,result,results);
        summer(node.right,result,results);
    }
}
